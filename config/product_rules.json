{
  "version": "1.0.1",
  "currency": "BRL",
  "locale": "pt-BR",
  "defaults": {
    "enabled": true,
    "publish_only_if_active_institution": true,
    "drop_records_without_institution_id": false,
    "drop_records_without_cnpj_root": true,
    "drop_records_without_segment": true,
    "drop_records_without_credit_value": false,
    "drop_records_without_term_months": false,
    "missing_numeric_value": null,
    "missing_text_value": null,
    "string_normalization": {
      "trim": true,
      "collapse_spaces": true,
      "uppercase_compare": true,
      "remove_accents_for_matching": true
    }
  },
  "families": {
    "carro": {
      "enabled": true,
      "label": "Consórcio de carro",
      "landing_route": "carro",
      "priority": 1,
      "match_any": [
        "AUTO",
        "AUTOMOVEL",
        "AUTOMÓVEL",
        "VEICULO",
        "VEÍCULO",
        "VEICULO LEVE",
        "VEÍCULO LEVE",
        "CARRO",
        "CAMINHONETE",
        "SUV",
        "PICKUP"
      ],
      "exclude_any": [
        "MOTO",
        "MOTOCICLETA",
        "IMOVEL",
        "IMÓVEL",
        "SERVICO",
        "SERVIÇO",
        "PESADO",
        "CAMINHAO",
        "CAMINHÃO",
        "ONIBUS",
        "ÔNIBUS",
        "NAUTICO",
        "NÁUTICO"
      ],
      "comparable": true
    },
    "moto": {
      "enabled": true,
      "label": "Consórcio de moto",
      "landing_route": "moto",
      "priority": 2,
      "match_any": [
        "MOTO",
        "MOTOCICLETA",
        "MOTOS",
        "MOTOCICLETAS"
      ],
      "exclude_any": [
        "AUTO",
        "AUTOMOVEL",
        "AUTOMÓVEL",
        "IMOVEL",
        "IMÓVEL",
        "SERVICO",
        "SERVIÇO",
        "NAUTICO",
        "NÁUTICO"
      ],
      "comparable": true
    },
    "imobiliario": {
      "enabled": true,
      "label": "Consórcio imobiliário",
      "landing_route": "imobiliario",
      "priority": 3,
      "match_any": [
        "IMOVEL",
        "IMÓVEL",
        "IMOBILIARIO",
        "IMOBILIÁRIO",
        "CASA",
        "APARTAMENTO",
        "TERRENO",
        "CONSTRUCAO",
        "CONSTRUÇÃO",
        "REFORMA"
      ],
      "exclude_any": [
        "AUTO",
        "AUTOMOVEL",
        "AUTOMÓVEL",
        "MOTO",
        "MOTOCICLETA",
        "SERVICO",
        "SERVIÇO",
        "NAUTICO",
        "NÁUTICO"
      ],
      "comparable": true
    },
    "servicos": {
      "enabled": false,
      "label": "Consórcio de serviços",
      "landing_route": null,
      "priority": 10,
      "match_any": [
        "SERVICO",
        "SERVIÇO",
        "SERVICOS",
        "SERVIÇOS"
      ],
      "exclude_any": [],
      "comparable": false
    },
    "pesados": {
      "enabled": false,
      "label": "Consórcio de pesados",
      "landing_route": null,
      "priority": 11,
      "match_any": [
        "CAMINHAO",
        "CAMINHÃO",
        "ONIBUS",
        "ÔNIBUS",
        "MAQUINA",
        "MÁQUINA",
        "TRATOR",
        "IMPLEMENTO"
      ],
      "exclude_any": [],
      "comparable": false
    },
    "nautico": {
      "enabled": false,
      "label": "Consórcio náutico",
      "landing_route": null,
      "priority": 12,
      "match_any": [
        "NAUTICO",
        "NÁUTICO",
        "BARCO",
        "LANCHA",
        "JET SKI"
      ],
      "exclude_any": [],
      "comparable": false
    },
    "carta_contemplada": {
      "enabled": false,
      "label": "Carta contemplada",
      "landing_route": "carta-contemplada",
      "priority": 99,
      "match_any": [
        "CARTA CONTEMPLADA"
      ],
      "exclude_any": [],
      "comparable": false,
      "editorial_only": true
    }
  },
