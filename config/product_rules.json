  "publication_rules": {
    "require_minimum_fields": [
      "cnpj_root",
      "segment"
    ],
    "prefer_records_with": [
      "credit_value",
      "term_months",
      "admin_fee_percent"
    ],
    "discard_if_segment_disabled": true,
    "discard_if_editorial_only": true,
    "max_products_per_institution_per_cluster": 50
  },
  "comparison_rules": {
    "same_segment_required": true,
    "same_credit_band_preferred": true,
    "same_term_band_preferred": true,
    "credit_tolerance_percent": 20,
    "term_tolerance_months": 12,
    "allow_cross_subsegment": true,
    "comparison_cluster_template": "{segment}:{credit_band}:{term_band}"
  },
  "sorting_defaults": {
    "global": [
      "segment_priority",
      "credit_value",
      "term_months",
      "admin_fee_percent"
    ],
    "carro": [
