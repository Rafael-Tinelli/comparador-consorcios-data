  "normalization": {
    "numeric": {
      "decimal_separator_auto_detect": true,
      "strip_currency_symbols": true,
      "strip_percent_symbols": true,
      "empty_to_null": true,
      "negative_to_null": true
    },
    "text": {
      "title_case_labels": false,
      "keep_original_value": true,
      "store_normalized_value": true
    },
    "derived_fields": {
      "build_product_slug": true,
      "build_credit_band": true,
      "build_term_band": true,
      "build_admin_fee_band": true,
      "build_total_fee_percent": true,
      "build_comparison_cluster_key": true
    }
  },
