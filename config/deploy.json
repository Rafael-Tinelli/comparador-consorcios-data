{
  "version": "2.0.0",
  "environment": "production",
  "timezone": "America/Sao_Paulo",
  "deploy_enabled": true,
  "deploy_mode": "hostgator_pull_cron",
  "validate_after_publish": true,
  "rollback_enabled": true,

  "project": {
    "name": "comparador-consorcios-data",
    "artifact_source_base": "data/dist",
    "artifact_source_global_dir": "data/dist/global",
    "artifact_source_seo_dir": "data/dist/seo",
    "manifest_strategy": "use_global_meta_json"
  },

  "source": {
    "provider": "github_raw",
    "repository": "Rafael-Tinelli/comparador-consorcios-data",
    "branch": "main",
    "base_raw_url": "https://raw.githubusercontent.com/Rafael-Tinelli/comparador-consorcios-data/main/data/dist",
    "manifest_relative_path": "global/meta.json",
    "global_relative_dir": "global",
    "seo_relative_dir": "seo",
    "notes": "O servidor consulta primeiro global/meta.json. Se houver mudança, baixa os demais JSONs."
  },

  "target": {
    "hostgator": {
      "base_dir": "/home1/SEU_USUARIO/consorcio-data",
      "releases_dir": "/home1/SEU_USUARIO/consorcio-data/releases",
      "current_dir": "/home1/SEU_USUARIO/consorcio-data/current",
      "tmp_dir": "/home1/SEU_USUARIO/consorcio-data/_tmp",
      "logs_dir": "/home1/SEU_USUARIO/consorcio-data/logs",
      "state_dir": "/home1/SEU_USUARIO/consorcio-data/state",
      "state_file": "/home1/SEU_USUARIO/consorcio-data/state/current_manifest.json"
    },
    "public_frontend": {
      "base_dir": "/public_html/financas/consorcio",
      "deploy_frontend_files": false,
      "notes": "O frontend PHP/CSS/JS permanece no HostGator e não faz parte da publicação de dados."
    }
  },

  "artifacts": {
    "global": [
      "instituicoes.json",
      "produtos.json",
      "rankings.json",
      "series.json",
      "cenarios.json",
      "autocomplete.json",
      "meta.json"
    ],
    "seo": [
      "defaults.json",
      "routes.json",
      "site.json"
    ]
  },

  "pull": {
    "strategy": "manifest_then_download",
    "download_mode": "file_by_file",
    "publish_only_on_change": true,
    "require_complete_release": true,
    "compare_using": "sha256_or_generated_at",
    "cron_recommended": "*/30 * * * *",
    "timeout_seconds": 60,
    "retry_count": 3,
    "user_agent": "comparador-consorcios-cron/1.0",
    "atomic_publish": "directory_swap",
    "keep_releases": 10
  },

  "validation": {
    "enabled": true,
    "fail_if_any_expected_file_missing": true,
    "fail_if_any_expected_file_is_empty": true,
    "fail_if_json_invalid": true,
    "required_paths_after_publish": [
      "/home1/SEU_USUARIO/consorcio-data/current/global/instituicoes.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/produtos.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/rankings.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/series.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/cenarios.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/autocomplete.json",
      "/home1/SEU_USUARIO/consorcio-data/current/global/meta.json",
      "/home1/SEU_USUARIO/consorcio-data/current/seo/defaults.json",
      "/home1/SEU_USUARIO/consorcio-data/current/seo/routes.json",
      "/home1/SEU_USUARIO/consorcio-data/current/seo/site.json"
    ],
    "meta_checks": {
      "path": "/home1/SEU_USUARIO/consorcio-data/current/global/meta.json",
      "required_fields": [
        "project",
        "counts",
        "source_runtime",
        "hashes"
      ]
    }
  },

  "rollback": {
    "enabled": true,
    "trigger_on_validation_failure": true,
    "trigger_on_missing_required_files": true,
    "trigger_on_invalid_json": true,
    "rollback_source": "previous_release",
    "write_rollback_log_entry": true
  },

  "logs": {
    "publish_log_file": "/home1/SEU_USUARIO/consorcio-data/logs/publish.log",
    "validate_log_file": "/home1/SEU_USUARIO/consorcio-data/logs/validate.log",
    "rollback_log_file": "/home1/SEU_USUARIO/consorcio-data/logs/rollback.log",
    "log_format": "text",
    "include_timestamp": true,
    "include_release_id": true,
    "include_changed_files_count": true
  },

  "workflow_integration": {
    "build_workflow_file": ".github/workflows/08-build-read-models.yml",
    "deploy_workflow_file": ".github/workflows/09-deploy-hostgator.yml",
    "validate_workflow_file": ".github/workflows/10-validate-hostgator.yml",
    "run_server_pull_independently_of_github": true,
    "publish_only_after_successful_build": true,
    "publish_only_on_change": true
  },

  "remote_commands": {
    "notes": [
      "A publicação passa a ser feita por script local no HostGator acionado por cron.",
      "O script consulta primeiro global/meta.json no GitHub Raw.",
      "Se houver nova versão, baixa os JSONs para uma pasta temporária.",
      "Depois valida, cria release local e troca current de forma atômica."
    ]
  },

  "secrets": {
    "required": [],
    "optional": []
  },

  "safety_flags": {
    "never_delete_base_dir": true,
    "never_touch_public_html_in_data_publish": true,
    "never_publish_partial_current": true,
    "never_skip_validation_when_enabled": true
  }
}
